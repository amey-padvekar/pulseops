{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulseops.local/schemas/telemetry.schema.json",
  "title": "PulseOps Telemetry Event",
  "description": "Telemetry payload sent by endpoint agent to backend.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deviceId",
    "timestamp",
    "heartbeat",
    "serviceName",
    "serviceStatus",
    "networkReachable",
    "cpuUsage",
    "memoryUsage",
    "recentLogs"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "deviceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Event timestamp generated by the agent in UTC."
    },
    "heartbeat": {
      "type": "boolean"
    },
    "serviceName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "serviceStatus": {
      "type": "string",
      "enum": [
        "running",
        "stopped",
        "degraded",
        "unknown"
      ]
    },
    "networkReachable": {
      "type": "boolean"
    },
    "cpuUsage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "memoryUsage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "recentLogs": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "string",
        "maxLength": 2048
      }
    },
    "incidentId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    }
  }
}
