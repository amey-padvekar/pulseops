# Backend runtime
APP_ENV=development
LOG_LEVEL=info
BACKEND_PORT=8080
FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Incident handling defaults
INCIDENT_VALIDATION_WINDOW_SECONDS=20

# Elastic connectivity (non-secret placeholders)
ELASTIC_ENDPOINT=https://your-elastic-endpoint.example.com
ELASTIC_INDEX_TELEMETRY=telemetry-events-local
ELASTIC_INDEX_INCIDENTS=incident-events-local
ELASTIC_INDEX_LOGS=endpoint-logs-local
ELASTIC_API_KEY=<set-in-local-.env-only>

# Agent Builder / Gemini orchestration placeholders
AGENT_BUILDER_ENDPOINT=https://your-agent-builder-endpoint.example.com
AGENT_BUILDER_AUTH=<set-in-local-.env-only>
GEMINI_PROJECT_OR_PROFILE=your-project-or-profile
