# Agent runtime
APP_ENV=development
LOG_LEVEL=info

# Agent identity and telemetry cadence
AGENT_DEVICE_ID=DEV-AGENT-01
AGENT_HEARTBEAT_INTERVAL_SEC=10
MONITORED_SERVICE_NAME=OpenVPNService

# Backend connectivity
BACKEND_BASE_URL=http://localhost:8080
AGENT_REQUEST_TIMEOUT_MS=5000

# Optional demo toggles
ENABLE_SIMULATED_LOGS=true
NETWORK_CHECK_HOST=8.8.8.8
